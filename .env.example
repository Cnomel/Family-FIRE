# === App Settings ===
APP_NAME=Family Fire
APP_VERSION=0.1.0
DEBUG=true
API_PREFIX=/api
TIMEZONE=Asia/Shanghai

# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/family_fire
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# === Redis ===
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# === MinIO ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_DOCUMENTS=family-fire-documents

# === JWT ===
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Security ===
PASSWORD_MIN_LENGTH=8
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30
RATE_LIMIT_PER_MINUTE=60

# === Financial APIs ===
ALPHAVANTAGE_API_KEY=
COINGECKO_API_KEY=
YAHOO_FINANCE_ENABLED=true

# === Family Settings ===
DEFAULT_MAX_FAMILIES_PER_USER=3

# === CORS ===
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
