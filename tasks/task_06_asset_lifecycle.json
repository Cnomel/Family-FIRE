{
  "id": "T6",
  "name": "资产生命周期与关系图谱",
  "name_en": "Asset Lifecycle & Relationship Graph",
  "branch": "feat/asset-lifecycle",
  "dependencies": ["T5"],
  "priority": "high",
  "status": "pending",
  "description": "实现智能的资产价值追踪和关系分析。包括6种生命周期轨迹计算、10种关系类型、级联分析、Celery定时任务。",
  "deliverables": [
    "backend/app/assets/lifecycle/base.py — 生命周期计算基类",
    "backend/app/assets/lifecycle/depreciating.py — 折旧计算（直线法、余额递减法）",
    "backend/app/assets/lifecycle/consumable.py — 消耗品追踪",
    "backend/app/assets/lifecycle/expiring.py — 到期管理",
    "backend/app/assets/lifecycle/volatile.py — 波动资产",
    "backend/app/assets/lifecycle/appreciating.py — 增值计算",
    "backend/app/assets/lifecycle/stable.py — 稳定资产",
    "backend/app/assets/relationships.py — 关系管理服务",
    "backend/app/assets/tasks.py — Celery定时任务"
  ],
  "api_endpoints": [
    "GET /api/assets/:id/lifecycle — 生命周期状态和计算结果",
    "PUT /api/assets/:id/lifecycle — 更新生命周期配置",
    "GET /api/assets/:id/value-history — 价值变化时间序列",
    "GET /api/assets/:id/relationships — 关联资产列表",
    "POST /api/assets/:id/relationships — 创建关系",
    "DELETE /api/assets/:id/relationships/:rid — 删除关系",
    "GET /api/families/:id/relationship-graph — 家庭资产关系图（节点+边）",
    "GET /api/families/:id/insurance-gaps — 保险缺口分析",
    "GET /api/families/:id/depreciation-report — 折旧报告"
  ],
  "acceptance_criteria": [
    "直线法折旧计算正确",
    "余额递减法折旧计算正确",
    "消耗品数量追踪正确",
    "消耗品消耗率预测正确",
    "到期提醒时间正确",
    "增值计算正确",
    "10种关系类型创建成功",
    "关系图谱数据结构正确",
    "保险缺口分析正确",
    "Celery定时任务执行成功"
  ],
  "tests": [
    "test_straight_line_depreciation — 直线法折旧",
    "test_declining_balance_depreciation — 余额递减法",
    "test_consumable_tracking — 消耗品追踪",
    "test_consumable_reorder_alert — 补货提醒",
    "test_expiring_asset_alert — 到期提醒",
    "test_appreciating_asset — 增值计算",
    "test_volatile_asset — 波动资产",
    "test_create_relationship — 创建关系",
    "test_relationship_graph — 关系图谱",
    "test_insurance_gap_analysis — 保险缺口",
    "test_cascade_notification — 级联通知",
    "test_celery_depreciation_task — 折旧定时任务",
    "test_celery_expiration_check — 到期检查任务"
  ],
  "chinese_localization_notes": [
    "折旧报告中文格式",
    "到期提醒中文消息：'您的{资产名称}将在{天数}天后到期'",
    "补货提醒：'{消耗品名称}库存不足，当前剩余{数量}{单位}'"
  ],
  "references": [
    "会计折旧方法标准",
    "东方财富资产分析"
  ],
  "notes": "生命周期计算是FIRE引擎的基础。定时任务使用Celery Beat调度。关系图谱数据格式需适配前端可视化组件。"
