{
  "id": "T4",
  "name": "家庭管理系统",
  "name_en": "Family Management System",
  "branch": "feat/family-management",
  "dependencies": ["T3"],
  "priority": "high",
  "status": "pending",
  "description": "实现完整的家庭协作管理，包括家庭创建、邀请码系统、成员管理、权限控制、重复资产检测。",
  "deliverables": [
    "backend/app/families/router.py — 家庭API路由",
    "backend/app/families/service.py — 家庭业务逻辑",
    "backend/app/families/schemas.py — 家庭Schema"
  ],
  "api_endpoints": [
    "POST /api/families — 创建家庭（检查数量限制）",
    "GET /api/families — 用户的家庭列表",
    "GET /api/families/:id — 家庭详情",
    "PUT /api/families/:id — 更新家庭（Family Admin）",
    "DELETE /api/families/:id — 删除家庭（Family Admin）",
    "POST /api/families/:id/invite — 生成邀请码（Family Admin）",
    "POST /api/families/join/:code — 通过邀请码加入",
    "GET /api/families/:id/members — 成员列表",
    "DELETE /api/families/:id/members/:uid — 移除成员（Family Admin）",
    "PUT /api/families/:id/members/:uid/role — 修改角色（Family Admin）"
  ],
  "acceptance_criteria": [
    "创建家庭成功",
    "超过数量限制创建失败",
    "邀请码生成成功（6位，7天过期）",
    "邀请码加入成功",
    "过期邀请码拒绝",
    "已使用的邀请码拒绝",
    "Family Admin可移除成员",
    "Member不可移除成员",
    "跨家庭数据隔离",
    "删除家庭级联软删除资产"
  ],
  "tests": [
    "test_create_family — 创建家庭",
    "test_create_family_limit_exceeded — 超过数量限制",
    "test_generate_invite_code — 生成邀请码",
    "test_join_with_valid_code — 有效邀请码加入",
    "test_join_with_expired_code — 过期邀请码",
    "test_join_with_used_code — 已使用邀请码",
    "test_remove_member — 移除成员",
    "test_member_cannot_remove — Member无权移除",
    "test_change_member_role — 修改角色",
    "test_family_isolation — 跨家庭隔离",
    "test_delete_family_cascade — 删除家庭级联"
  ],
  "chinese_localization_notes": [
    "邀请码格式：6位大写字母+数字，如 'A3B7C2'",
    "提示消息：'家庭数量已达上限'、'邀请码已过期'、'邀请码已被使用'",
    "家庭角色：'管理员'、'成员'"
  ],
  "references": [
    "支付宝家庭账户设计",
    "微信家庭群管理"
  ],
  "notes": "家庭是资产隔离的基本单位。每个用户可创建的家庭数量由Admin在system_settings中全局配置。"
}
