{
  "id": "T3",
  "name": "认证与用户系统",
  "name_en": "Authentication & User System",
  "branch": "feat/auth-user",
  "dependencies": ["T2"],
  "priority": "high",
  "status": "pending",
  "description": "实现生产级认证系统，支持用户名或邮箱登录、JWT Token、RBAC权限、速率限制、密码重置等完整安全特性。",
  "deliverables": [
    "backend/app/auth/router.py — 认证API路由",
    "backend/app/auth/service.py — 认证业务逻辑",
    "backend/app/auth/schemas.py — 认证Schema（LoginRequest, RegisterRequest, TokenResponse等）",
    "backend/app/auth/dependencies.py — 认证依赖（get_current_user, require_role）",
    "backend/app/users/router.py — 用户管理API路由",
    "backend/app/users/service.py — 用户业务逻辑",
    "backend/app/users/schemas.py — 用户Schema",
    "backend/app/common/security.py — JWT生成/验证、密码哈希、Token黑名单"
  ],
  "api_endpoints": [
    "POST /api/auth/register — 用户注册（用户名+邮箱+密码）",
    "POST /api/auth/login — 登录（用户名或邮箱+密码，自动识别）",
    "POST /api/auth/refresh — 刷新Token",
    "POST /api/auth/logout — 登出（Token加入Redis黑名单）",
    "GET /api/auth/me — 获取当前用户信息",
    "PUT /api/auth/me — 更新个人信息",
    "PUT /api/auth/password — 修改密码",
    "POST /api/auth/password/forgot — 忘记密码",
    "POST /api/auth/password/reset — 重置密码",
    "GET /api/users — 用户列表（Admin）",
    "GET /api/users/:id — 用户详情（Admin）",
    "PUT /api/users/:id/role — 修改角色（Admin）",
    "PUT /api/users/:id/status — 启用/禁用（Admin）"
  ],
  "acceptance_criteria": [
    "用户名登录成功",
    "邮箱登录成功",
    "重复用户名注册失败",
    "重复邮箱注册失败",
    "弱密码注册失败",
    "登录失败5次后锁定30分钟",
    "Token刷新成功",
    "过期Token拒绝访问",
    "黑名单Token拒绝访问",
    "Admin角色可访问用户管理API",
    "Member角色不可访问用户管理API",
    "速率限制生效"
  ],
  "tests": [
    "test_register_success — 注册成功",
    "test_register_duplicate_username — 重复用户名",
    "test_register_duplicate_email — 重复邮箱",
    "test_register_weak_password — 弱密码",
    "test_login_with_username — 用户名登录",
    "test_login_with_email — 邮箱登录",
    "test_login_wrong_password — 错误密码",
    "test_login_account_lockout — 账号锁定",
    "test_token_refresh — Token刷新",
    "test_token_blacklist — Token黑名单",
    "test_logout — 登出",
    "test_get_me — 获取当前用户",
    "test_update_profile — 更新资料",
    "test_change_password — 修改密码",
    "test_admin_access — Admin权限",
    "test_member_cannot_access_admin — Member无Admin权限",
    "test_rate_limiting — 速率限制"
  ],
  "chinese_localization_notes": [
    "用户名规则：3-20位，支持字母、数字、下划线、中文",
    "错误消息中文：'用户名已存在'、'邮箱已注册'、'密码强度不足'",
    "登录提示：'账号已锁定，请30分钟后重试'",
    "密码强度规则：8位以上，包含大小写字母和数字"
  ],
  "references": [
    "JWT最佳实践: https://tools.ietf.org/html/rfc7519",
    "OWASP认证指南",
    "招商银行App登录流程"
  ],
  "notes": "登录支持用户名或邮箱，系统自动判断输入类型（包含@则为邮箱，否则为用户名）。安全是第一优先级。"
}
